# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=admin
DB_PASSWORD=admin
DB_DATABASE=ai_writing

# Application Configuration
APP_PORT=8000
NODE_ENV=development
AUTO_RUN_MIGRATION=true

# Frontend URL (origin FE — dùng cho CORS, không có /api)
FRONTEND_URL=http://localhost:3000

# Tuỳ chọn — URL public của BE cho Swagger "Try it out"
# Để trống thì Swagger tự dùng domain đang mở trang /api/docs
# API_PUBLIC_URL=https://ai-wrining-personally.vercel.app

# Cookie Configuration
COOKIE_ACCESS_TOKEN_EXPIRATION_TIME=3600
COOKIE_ACCESS_TOKEN_NAME=access_token

# JWT Configuration
JWT_SECRET=your_secret_key_here
JWT_EXPIRATION_TIME=3600
JWT_COOKIE_NAME=jwt_token

# Google Gemini (free key: https://aistudio.google.com/apikey)
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.5-flash-lite
GEMINI_FALLBACK_MODELS=gemini-3.5-flash,gemini-3.1-flash-lite,gemini-2.5-flash
GEMINI_TEMPERATURE=0.4
GEMINI_MAX_OUTPUT_TOKENS=4096
DAILY_TOKEN_LIMIT=50000
TOKEN_BUFFER_PERCENT=0.1
