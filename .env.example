# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=admin
DB_PASSWORD=admin
DB_DATABASE=ai_writing

# Application Configuration
APP_PORT=8000
NODE_ENV=development
AUTO_RUN_MIGRATION=true

# Frontend URL
FRONTEND_URL=http://localhost:3000

# Cookie Configuration
COOKIE_ACCESS_TOKEN_EXPIRATION_TIME=3600
COOKIE_ACCESS_TOKEN_NAME=access_token

# JWT Configuration
JWT_SECRET=your_secret_key_here
JWT_EXPIRATION_TIME=3600
JWT_COOKIE_NAME=jwt_token

# OpenRouter AI Configuration
ONEROUTER_API_KEY=your_openrouter_api_key
ONEROUTER_MODEL=poolside/laguna-xs.2:free
ONEROUTER_TEMPERATURE=0.4
ONEROUTER_MAX_TOKENS=3500
DAILY_TOKEN_LIMIT=50000
TOKEN_BUFFER_PERCENT=0.1
